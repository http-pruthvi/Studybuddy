# StudyBuddy Server Configurations Example
# Rename this file to '.env' and fill in your keys.

SARVAM_API_KEY=your_sarvam_api_subscription_key
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_aura_password
GEMINI_API_KEY=your_gemini_api_key
JWT_SECRET=your_secret_signing_key_here
ALLOWED_ORIGINS=*
